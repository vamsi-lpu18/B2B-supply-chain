{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Service": {
    "Name": "IdentityAuth",
    "Port": 8001
  },
  "ConnectionStrings": {
    "IdentityDb": "Server=localhost;Database=IdentityAuthMigrationsDB;Trusted_Connection=True;TrustServerCertificate=True;",
    "Redis": "localhost:6380",
    "RabbitMq": "localhost:5673"
  },
  "Jwt": {
    "Issuer": "SupplyChainPlatform",
    "Audience": "SupplyChainPlatform.Client",
    "Audiences": [
      "SupplyChainPlatform.Client",
      "SupplyChainPlatform.Gateway"
    ],
    "SecretKey": "ThisIsADevelopmentOnlySecretKey_ChangeForProduction_2026",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "AdminSeed": {
    "Email": "admin@supplychain.local",
    "Password": "Admin@1234",
    "FullName": "Platform Admin",
    "PhoneNumber": "9999999999"
  },
  "ExternalServices": {
    "PaymentBaseUrl": "http://localhost:8005",
    "NotificationBaseUrl": "http://localhost:8006"
  },
  "InternalApi": {
    "Key": "SupplyChainInternalKey_ChangeInProduction"
  }
}
