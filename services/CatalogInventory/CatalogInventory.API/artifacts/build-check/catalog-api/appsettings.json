{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Service": {
    "Name": "CatalogInventory",
    "Port": 8002
  },
  "ConnectionStrings": {
    "InventoryDb": "Server=localhost;Database=CatalogInventoryMigrationsDB;Trusted_Connection=True;TrustServerCertificate=True;",
    "Redis": "localhost:6380",
    "RabbitMq": "localhost:5673"
  },
  "Jwt": {
    "Issuer": "SupplyChainPlatform",
    "Audience": "SupplyChainPlatform.Client",
    "Audiences": [
      "SupplyChainPlatform.Client",
      "SupplyChainPlatform.Gateway"
    ],
    "SecretKey": "ThisIsADevelopmentOnlySecretKey_ChangeForProduction_2026"
  },
  "InternalApi": {
    "Key": "SupplyChainInternalApiKey_DevOnly_2026"
  }
}
