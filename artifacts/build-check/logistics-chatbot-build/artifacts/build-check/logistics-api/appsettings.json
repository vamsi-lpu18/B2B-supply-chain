{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Service": {
    "Name": "LogisticsTracking",
    "Port": 8004
  },
  "ConnectionStrings": {
    "LogisticsDb": "Server=localhost;Database=LogisticsTrackingMigrationsDB;Trusted_Connection=True;TrustServerCertificate=True;",
    "Redis": "localhost:6380",
    "RabbitMq": "localhost:5673"
  },
  "Jwt": {
    "Issuer": "SupplyChainPlatform",
    "Audience": "SupplyChainPlatform.Client",
    "Audiences": [
      "SupplyChainPlatform.Client",
      "SupplyChainPlatform.Gateway"
    ],
    "SecretKey": "ThisIsADevelopmentOnlySecretKey_ChangeForProduction_2026"
  },
  "Ai": {
    "Provider": "gemini",
    "Enabled": false,
    "ApiKey": "",
    "Model": "gemini-2.0-flash",
    "EndpointBase": "https://generativelanguage.googleapis.com/v1beta/models",
    "TimeoutSeconds": 15,
    "Temperature": 0.2
  }
}
