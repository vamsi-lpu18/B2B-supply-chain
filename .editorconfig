root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{json,yml,yaml,md,xml}]
indent_size = 2

[*.{ts,tsx,js,jsx,css,scss,html}]
indent_size = 2

[*.cs]
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

csharp_style_namespace_declarations = file_scoped:suggestion
csharp_prefer_braces = true:warning
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = false:suggestion
csharp_style_var_elsewhere = false:suggestion

# Enterprise naming conventions

dotnet_naming_rule.interfaces_start_with_i.severity = warning
dotnet_naming_rule.interfaces_start_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_start_with_i.style = starts_with_i

dotnet_naming_rule.types_use_pascal_case.severity = warning
dotnet_naming_rule.types_use_pascal_case.symbols = types
dotnet_naming_rule.types_use_pascal_case.style = pascal_case_style

dotnet_naming_rule.members_use_pascal_case.severity = warning
dotnet_naming_rule.members_use_pascal_case.symbols = public_members
dotnet_naming_rule.members_use_pascal_case.style = pascal_case_style

dotnet_naming_rule.private_fields_use_underscore_prefix.severity = warning
dotnet_naming_rule.private_fields_use_underscore_prefix.symbols = private_fields
dotnet_naming_rule.private_fields_use_underscore_prefix.style = underscore_camel_case_style

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *

dotnet_naming_symbols.types.applicable_kinds = class, struct, interface, enum, delegate

# Includes methods, properties, events, and fields that are externally visible
dotnet_naming_symbols.public_members.applicable_kinds = method, property, event, field
dotnet_naming_symbols.public_members.applicable_accessibilities = public, protected, protected_internal

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.starts_with_i.required_prefix = I
dotnet_naming_style.starts_with_i.capitalization = pascal_case

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

dotnet_naming_style.underscore_camel_case_style.required_prefix = _
dotnet_naming_style.underscore_camel_case_style.capitalization = camel_case
